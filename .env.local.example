# =============================================
# CAROUSEL IG — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env.local e preencha os valores

# --- Claude / Anthropic API ---
# Obter em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Custom Search API ---
# API Key: https://console.cloud.google.com → "Custom Search API"
# Engine ID: https://programmablesearchengine.google.com
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SEARCH_ENGINE_ID=xxxxxxxxxxxxxxxxx

# --- Instagram Business Login ---
# App ID e Secret: https://developers.facebook.com → x-post-IG → Configurações básicas
# "API com login empresarial no Instagram"
INSTAGRAM_APP_ID=xxxxxxxxxxxxxxxxx
INSTAGRAM_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access Token e Account ID: obtidos automaticamente após conectar conta no editor
# (opcional: podem ser inseridos diretamente no modal de publicação)
NEXT_PUBLIC_IG_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_IG_ACCOUNT_ID=17841xxxxxxxxxxxxxxx

# --- Supabase ---
# URL do projeto: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Anon key (pública — usada apenas no client se necessário):
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx
# Service Role Key (secreta — NUNCA expor no client):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx
